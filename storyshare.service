[Unit]
Description=StoryShare Node.js Backend
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/storyshare/backend
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=storyshare
EnvironmentFile=/var/www/storyshare/backend/.env

[Install]
WantedBy=multi-user.target
